  const [saving, setSaving] = useState(false);

  const [formData, setFormData] = useState({
    client_names: '',
    wedding_date: '',
    location_name: '',
    price_czk: '',
    status: '',
    notes: ''
  });

  // Načtení dat stávající zakázky
  useEffect(() => {
    const fetchWedding = async () => {
      const { data, error } = await supabase
        .from('weddings')
        .select('*')
        .eq('id', params.id)
        .single();

      if (data) {
        setFormData({
          client_names: data.client_names,
